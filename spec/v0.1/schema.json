{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://universalmanifest.net/ns/universal-manifest/v0.1/schema.json",
  "title": "Universal Manifest (v0.1)",
  "type": "object",
  "required": [
    "@context",
    "@id",
    "@type",
    "manifestVersion",
    "subject",
    "issuedAt",
    "expiresAt"
  ],
  "properties": {
    "@context": {
      "description": "JSON-LD context URL/object/array. Use spec/v0.1/schema.jsonld or an equivalent hosted context.",
      "oneOf": [
        {
          "type": "string"
        },
        {
          "type": "object"
        },
        {
          "type": "array"
        }
      ]
    },
    "@id": {
      "type": "string",
      "minLength": 1
    },
    "@type": {
      "description": "Must include um:Manifest (string or array).",
      "oneOf": [
        {
          "type": "string"
        },
        {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        }
      ]
    },
    "manifestVersion": {
      "type": "string",
      "minLength": 1
    },
    "subject": {
      "type": "string",
      "minLength": 1
    },
    "issuedAt": {
      "type": "string",
      "format": "date-time"
    },
    "expiresAt": {
      "type": "string",
      "format": "date-time"
    },
    "facets": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/facet"
      }
    },
    "claims": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "consents": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "devices": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "pointers": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "signature": {
      "$ref": "#/$defs/signature"
    }
  },
  "additionalProperties": true,
  "$defs": {
    "facet": {
      "type": "object",
      "required": [
        "@type"
      ],
      "properties": {
        "@id": {
          "type": "string"
        },
        "@type": {
          "oneOf": [
            {
              "type": "string"
            },
            {
              "type": "array",
              "items": {
                "type": "string"
              },
              "minItems": 1
            }
          ]
        },
        "name": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "ref": {
          "type": "string"
        },
        "entity": {
          "type": [
            "object",
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": true
    },
    "signature": {
      "type": "object",
      "description": "Permissive v0.1 signature (format not locked yet).",
      "properties": {
        "algorithm": {
          "type": "string"
        },
        "keyRef": {
          "type": "string"
        },
        "value": {
          "type": "string"
        }
      },
      "additionalProperties": true
    }
  }
}